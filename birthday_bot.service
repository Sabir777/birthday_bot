[Unit]
Description=Telegram Birthday Bot
After=network.target

[Service]
Type=simple
User=krolik
WorkingDirectory=/home/krolik/QWEN/birthday_bot
Environment=PATH=/home/krolik/QWEN/birthday_bot/venv/bin
ExecStart=/home/krolik/QWEN/birthday_bot/venv/bin/python bot.py
Restart=on-failure

[Install]
WantedBy=multi-user.target
